---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  lead?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const { title, description, lead, ogTitle, ogDescription, ogImage } = Astro.props;
---

<BaseLayout
  title={`${title} | Geolonia`}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
>
  <div class="page-container">
    <div class="hero-section">
      <div class="container">
        <h1>{title}</h1>
        {lead && <p class="lead">{lead}</p>}
      </div>
    </div>

    <div class="content-section">
      <div class="container markdown-content">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>

<style is:inline>
  .page-container {
    padding-top: 0;
  }

  .hero-section {
    background: linear-gradient(135deg, #f39813 0%, #eb5722 100%);
    color: white;
    padding: 100px 0 80px;
    margin-bottom: 60px;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .hero-section h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 1rem 0;
    font-weight: 700;
    text-wrap: balance;
    letter-spacing: 0.02em;
  }

  .lead {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    margin: 0;
    opacity: 0.9;
  }

  .content-section {
    padding: 0 0 80px 0;
  }

  .markdown-content h2,
  .markdown-content h3,
  .markdown-content h4 {
    text-wrap: balance;
  }

  .markdown-content h2 {
    color: #f39813;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin-bottom: 1.5rem;
    margin-top: 2.5rem;
    letter-spacing: 0.01em;
  }

  .markdown-content h2:first-child {
    margin-top: 0;
  }

  .markdown-content h3 {
    color: #333;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .markdown-content h4 {
    color: #333;
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    margin-top: 1.5rem;
    margin-bottom: 0.8rem;
  }

  .markdown-content p {
    line-height: 1.8;
    margin-bottom: 1rem;
    max-width: 720px;
  }

  .markdown-content ul,
  .markdown-content ol {
    line-height: 1.8;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .markdown-content li {
    margin-bottom: 0.5rem;
  }

  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
  }

  .markdown-content th,
  .markdown-content td {
    padding: 1rem;
    border-bottom: 1px solid #e0e0e0;
    text-align: left;
  }

  .markdown-content th {
    background-color: #f5f5f5;
    font-weight: 700;
  }

  .markdown-content td {
    line-height: 1.8;
  }

  .markdown-content a {
    color: #f39813;
    text-decoration: none;
  }

  .markdown-content a:hover {
    text-decoration: underline;
  }

  .markdown-content hr {
    border: none;
    border-top: 1px solid #e0e0e0;
    margin: 3rem 0;
  }

  .markdown-content blockquote {
    border-left: 4px solid #f39813;
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: #666;
  }

  .markdown-content code {
    background-color: #f7f7f8;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875em;
    color: #d63384;
    border: 1px solid #eee;
    font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, "DejaVu Sans Mono", monospace;
  }

  .markdown-content .code-block-wrapper {
    position: relative;
    margin: 1.5rem 0;
  }

  .markdown-content .code-block-wrapper .code-lang-label {
    position: absolute;
    top: 0;
    left: 0;
    background: #f39813;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 8px 0 4px 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 1;
    font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, monospace;
  }

  .markdown-content .code-block-wrapper .code-copy-btn {
    position: absolute;
    top: 6px;
    right: 6px;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    border: none;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
    z-index: 1;
    font-family: inherit;
  }

  .markdown-content .code-block-wrapper .code-copy-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .markdown-content .code-block-wrapper .code-copy-btn.copied {
    background: rgba(243, 152, 19, 0.3);
    color: #f39813;
  }

  .markdown-content pre {
    background-color: #1e1e2e;
    color: #cdd6f4;
    padding: 1rem 1.5rem;
    padding-top: 2.5rem;
    font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, "DejaVu Sans Mono", monospace;
    border-radius: 8px;
    overflow-x: auto;
    margin: 0;
    border: 1px solid #333;
    line-height: 1.7;
    font-size: 1rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .markdown-content pre code {
    background-color: transparent;
    padding: 0;
    color: inherit;
    border: none;
    font-size: inherit;
    font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, "DejaVu Sans Mono", monospace;
  }

  @media (max-width: 768px) {
    .markdown-content th,
    .markdown-content td {
      padding: 0.8rem;
      font-size: 0.9rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.markdown-content pre').forEach((pre) => {
    const lang = pre.getAttribute('data-language');
    if (!lang || !pre.parentNode) return;

    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    pre.parentNode.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const label = document.createElement('span');
    label.className = 'code-lang-label';
    label.textContent = lang;
    wrapper.appendChild(label);

    const btn = document.createElement('button');
    btn.className = 'code-copy-btn';
    btn.textContent = 'Copy';
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      if (!code) return;

      if (!navigator.clipboard?.writeText) {
        btn.textContent = 'Failed';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        return;
      }

      try {
        await navigator.clipboard.writeText(code.textContent || '');
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      } catch {
        btn.textContent = 'Failed';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      }
    });
    wrapper.appendChild(btn);
  });
</script>
